{
	"name": "crate-guide",
	"author": {
		"name": "Ryan Voitiskis",
		"email": "ryanvoitiskis@protonmail.com",
		"url": "https://ryanvoitiskis.com"
	},
	"engines": {
		"node": ">=24.12.0",
		"npm": ">=11.6.2"
	},
	"private": true,
	"license": "AGPL-3.0-only",
	"type": "module",
	"scripts": {
		"test": "vitest --project unit --project stores --project server",
		"test:run": "vitest run --project unit --project stores --project server",
		"test:unit": "vitest --project unit",
		"test:e2e": "vitest run --project e2e",
		"check:edge": "cd supabase && deno task check",
		"lint:edge": "cd supabase && deno task lint",
		"test:edge": "cd supabase && deno task test",
		"build": "nuxt build",
		"dev": "nuxt dev",
		"dev:all": "./scripts/dev-start.sh",
		"generate": "nuxt generate",
		"preview": "nuxt preview",
		"postinstall": "nuxt prepare",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"typecheck": "nuxt typecheck",
		"format": "prettier --write '**/*.{ts,js,vue,scss,css,md,json}'",
		"supa:start": "supabase start && supabase functions serve --no-verify-jwt &",
		"supa:stop": "supabase stop",
		"supa:restart": "supabase stop && supabase start",
		"supa:functions": "supabase functions serve --no-verify-jwt",
		"supa:reset": "supabase db reset",
		"setStagingSecrets": "npx supabase secrets set --project-ref=$SUPABASE_PROJECT_REF --env-file ./supabase/functions/.env",
		"genTypes": "supabase gen types --lang=typescript --local > shared/types/database.ts && cp shared/types/database.ts supabase/functions/_shared/types/database.ts"
	},
	"dependencies": {
		"@nuxtjs/supabase": "^2.0.4",
		"@pinia/nuxt": "^0.11.3",
		"@tanstack/vue-table": "^8.21.3",
		"@vee-validate/zod": "^4.15.1",
		"@vueuse/core": "^14.2.1",
		"@vueuse/integrations": "^14.2.1",
		"@vueuse/nuxt": "^14.2.1",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"essentia.js": "0.1.3",
		"lucide-vue-next": "^0.575.0",
		"music-metadata": "11.13.0",
		"nuxt": "^4.4.2",
		"pinia": "^3.0.4",
		"reka-ui": "^2.9.3",
		"sortablejs": "^1.15.7",
		"tailwind-merge": "^3.5.0",
		"vee-validate": "^4.15.1",
		"vue": "3.5.32",
		"vue-sonner": "^2.0.9",
		"zod": "^3.25.76"
	},
	"devDependencies": {
		"@nuxt/eslint": "^1.15.2",
		"@nuxt/test-utils": "^4.0.0",
		"@pinia/testing": "^1.0.3",
		"@tailwindcss/vite": "^4.2.2",
		"@trivago/prettier-plugin-sort-imports": "^6.0.2",
		"@types/jsdom": "^27.0.0",
		"@types/sortablejs": "^1.15.9",
		"eslint": "^9.39.4",
		"happy-dom": "^20.10.6",
		"jsdom": "^28.1.0",
		"playwright-core": "^1.59.1",
		"prettier": "^3.8.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"sass": "^1.99.0",
		"shadcn-nuxt": "^2.4.3",
		"tailwindcss": "^4.2.2",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"vitest": "^4.1.2",
		"vue-tsc": "^3.2.6"
	},
	"overrides": {
		"vue": "3.5.32"
	},
	"prettier": {
		"useTabs": true,
		"singleQuote": true,
		"trailingComma": "none",
		"tabWidth": 2,
		"semi": false,
		"plugins": [
			"@trivago/prettier-plugin-sort-imports",
			"prettier-plugin-tailwindcss"
		],
		"htmlWhitespaceSensitivity": "ignore",
		"importOrder": [
			"^vue",
			"<THIRD_PARTY_MODULES>",
			"^[./]"
		],
		"importOrderSortSpecifiers": true,
		"tailwindFunctions": [
			"clsx",
			"cva",
			"cn"
		]
	}
}
