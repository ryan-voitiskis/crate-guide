{
	"name": "crate-guide",
	"author": {
		"name": "Ryan Voitiskis",
		"email": "ryanvoitiskis@protonmail.com",
		"url": "https://ryanvoitiskis.com"
	},
	"engines": {
		"node": ">=24.12.0",
		"npm": ">=11.6.2"
	},
	"private": true,
	"license": "AGPL-3.0-only",
	"type": "module",
	"scripts": {
		"test": "vitest --project unit --project stores --project server --project nuxt",
		"test:run": "vitest run --project unit --project stores --project server --project nuxt",
		"test:unit": "vitest --project unit",
		"test:nuxt": "vitest run --project nuxt",
		"test:e2e": "vitest run --project e2e",
		"test:browser": "vitest run --project browser",
		"test:audio-config": "node --test scripts/benchmark-local-audio.test.cjs",
		"test:conventions": "node --test scripts/check-conventions.test.mjs",
		"test:dependency-topology": "node --test scripts/check-dependency-topology.test.mjs",
		"test:dev-start-script": "node --test scripts/dev-start.test.mjs",
		"test:typegen-script": "node --test scripts/generate-database-types.test.mjs",
		"test:database-type-parity": "node --test scripts/check-database-type-parity.test.mjs",
		"audit:prod": "npm audit --omit=dev --audit-level=high",
		"audit:all": "npm audit --audit-level=high",
		"check:conventions": "node scripts/check-conventions.mjs",
		"check:database-types": "node scripts/check-database-type-parity.mjs",
		"check:dependency-topology": "node scripts/check-dependency-topology.mjs",
		"check:discogs-docs": "node scripts/check-discogs-doc-contract.mjs",
		"check:edge": "cd supabase && deno task check",
		"lint:edge": "cd supabase && deno task lint",
		"test:edge": "cd supabase && deno task test",
		"test:db": "supabase test db",
		"build": "nuxt build",
		"dev": "nuxt dev",
		"dev:all": "node scripts/dev-start.mjs --with-nuxt",
		"generate": "nuxt generate",
		"preview": "nuxt preview",
		"postinstall": "nuxt prepare",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"typecheck": "nuxt typecheck",
		"format": "prettier --write '**/*.{ts,js,mjs,cjs,mts,cts,vue,css,md,json}'",
		"format:check": "prettier --check '**/*.{ts,js,mjs,cjs,mts,cts,vue,css,md,json}'",
		"verify": "npm run format:check && npm run lint && npm run typecheck && npm run test:run && npm run test:e2e && npm run test:browser && npm run check:edge && npm run lint:edge && npm run test:edge && npm run test:typegen-script && npm run test:database-type-parity && npm run check:database-types && npm run test:audio-config && npm run test:dev-start-script && npm run test:conventions && npm run check:conventions && npm run check:discogs-docs && npm run test:dependency-topology && npm run check:dependency-topology",
		"verify:full": "npm run verify && npm run build && npm run test:db",
		"supa:start": "node scripts/dev-start.mjs",
		"supa:stop": "supabase stop",
		"supa:restart": "supabase stop && npm run supa:start",
		"supa:functions": "supabase functions serve --no-verify-jwt",
		"supa:health": "node scripts/dev-start.mjs --health-check-only",
		"supa:reset": "supabase db reset",
		"setStagingSecrets": "npx supabase secrets set --project-ref=$SUPABASE_PROJECT_REF --env-file ./supabase/functions/.env",
		"genTypes": "node scripts/generate-database-types.mjs"
	},
	"dependencies": {
		"@nuxtjs/supabase": "^2.0.4",
		"@pinia/nuxt": "^0.11.3",
		"@tanstack/vue-table": "^8.21.3",
		"@vee-validate/zod": "^4.15.1",
		"@vueuse/core": "^14.2.1",
		"@vueuse/integrations": "^14.2.1",
		"@vueuse/nuxt": "^14.2.1",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"essentia.js": "0.1.3",
		"lucide-vue-next": "^0.575.0",
		"music-metadata": "11.13.0",
		"nuxt": "^4.4.8",
		"pinia": "^3.0.4",
		"reka-ui": "^2.9.3",
		"sortablejs": "^1.15.7",
		"tailwind-merge": "^3.5.0",
		"vee-validate": "^4.15.1",
		"vue": "3.5.40",
		"vue-router": "5.2.0",
		"vue-sonner": "^2.0.9",
		"zod": "^3.25.76"
	},
	"devDependencies": {
		"@nuxt/eslint": "^1.15.2",
		"@nuxt/test-utils": "^4.0.3",
		"@pinia/testing": "^1.0.3",
		"@tailwindcss/vite": "^4.2.2",
		"@trivago/prettier-plugin-sort-imports": "^6.0.2",
		"@types/jsdom": "^27.0.0",
		"@types/sortablejs": "^1.15.9",
		"@vitest/browser-playwright": "4.1.10",
		"@vue/test-utils": "^2.4.11",
		"crossws": "0.4.1",
		"esbuild": "0.28.1",
		"eslint": "^9.39.4",
		"happy-dom": "^20.10.6",
		"jsdom": "^28.1.0",
		"playwright": "1.59.1",
		"playwright-core": "^1.59.1",
		"prettier": "^3.8.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"shadcn-nuxt": "^2.4.3",
		"supabase": "2.109.1",
		"tailwindcss": "^4.2.2",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"vitest": "4.1.10",
		"vue-tsc": "^3.2.6"
	},
	"overrides": {
		"vue": "3.5.40"
	},
	"prettier": {
		"useTabs": true,
		"singleQuote": true,
		"trailingComma": "none",
		"tabWidth": 2,
		"semi": false,
		"plugins": [
			"@trivago/prettier-plugin-sort-imports",
			"prettier-plugin-tailwindcss"
		],
		"htmlWhitespaceSensitivity": "ignore",
		"importOrder": [
			"^vue",
			"<THIRD_PARTY_MODULES>",
			"^[./]"
		],
		"importOrderSortSpecifiers": true,
		"tailwindFunctions": [
			"clsx",
			"cva",
			"cn"
		]
	}
}
